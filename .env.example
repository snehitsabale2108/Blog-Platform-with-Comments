# ══════════════════════════════════════════════════
#   Inkwell Blog Platform – Environment Variables
#   Copy this file to .env and fill in real values
# ══════════════════════════════════════════════════

# ─── Application ───
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-very-secret-key-change-this-in-production-min-32-chars
APP_URL=http://localhost:5000

# ─── Database ───
# SQLite (development - uses instance/dev.db by default)
DATABASE_URL=sqlite:///instance/dev.db

# PostgreSQL (production example)
# DATABASE_URL=postgresql://user:password@host:5432/inkwell

# ─── JWT ───
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ─── Email (Gmail SMTP example) ───
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=noreply@inkwell.com

# ─── File Uploads ───
# Max upload size is 5MB by default (see config.py)

# ─── Production Only ───
# Set these in your hosting dashboard, never commit real values
# JWT_COOKIE_SECURE=true
